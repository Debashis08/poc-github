{
  "pr_template": "- #{{TITLE}} ([##{{NUMBER}}](https://github.com/#{{OWNER}}/#{{REPO}}/pull/#{{NUMBER}}))",
  "ignore_labels": [
    "ignore-pr",
    "skip-changelog"
  ],
  "label_extractors": [
    {
      "pattern": "^(?!(feat|fix|build|ci|chore|env|refactor|perf|docs)(\\(.*\\))?:).*",
      "target": "ignore-pr",
      "on_property": "title"
    }
  ],
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": [],
      "pr_title_regex": "^feat(\\(.*\\))?:"
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": [],
      "pr_title_regex": "^fix(\\(.*\\))?:"
    },
    {
      "title": "## 🛠 Build System & Tooling",
      "labels": [],
      "pr_title_regex": "^(build|ci|chore|env)(\\(.*\\))?:"
    },
    {
      "title": "## ♻️ Core & Refactoring",
      "labels": [],
      "pr_title_regex": "^(refactor|perf)(\\(.*\\))?:"
    },
    {
      "title": "## 📝 Documentation",
      "labels": [],
      "pr_title_regex": "^docs(\\(.*\\))?:"
    }
  ],
  "replacers": [
    {
      "search": "/- (feat|fix|build|ci|chore|env|refactor|perf|docs)(\\(.*?\\))?:\\s*/ig",
      "replace": "- "
    }
  ],
  "template": "### Changes and updates in this release\n\n#{{CHANGELOG}}\n\n**Full Changelog:** https://github.com/#{{OWNER}}/#{{REPO}}/compare/#{{FROM_TAG}}...#{{TO_TAG}}"
}